# PostgreSQL Configuration (used by DB container & Spring Boot)
POSTGRES_DB=cx_broker_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_db_password
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/cx_broker_db

# RabbitMQ Configuration (used by RabbitMQ container & Spring Boot)
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=your_secure_rabbitmq_password
SPRING_RABBITMQ_HOST=rabbitmq
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=admin
SPRING_RABBITMQ_PASSWORD=your_secure_rabbitmq_password
